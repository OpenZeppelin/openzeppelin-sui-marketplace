{
  "name": "dapp",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Oracle Market",
  "scripts": {
    "ui": "pnpm --filter ui",
    "script": "pnpm --filter dapp",
    "dapp": "pnpm --filter dapp",
    "learn": "pnpm --filter learn",
    "tooling": "pnpm --filter tooling",
    "typecheck": "tsc -b",
    "lint": "eslint \"packages/**/*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}\"",
    "lint:fix": "eslint --fix \"packages/**/*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}\"",
    "env:bootstrap": "node scripts/activate-dapp-env.mjs bootstrap",
    "env:owner": "node scripts/activate-dapp-env.mjs owner",
    "env:buyer": "node scripts/activate-dapp-env.mjs buyer",
    "env:status": "node scripts/activate-dapp-env.mjs status"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.15",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "packages/*/*"
  ],
  "pnpm": {
    "overrides": {
      "axios": "1.13.5",
      "@isaacs/brace-expansion": "5.0.1",
      "minimatch": "10.2.4",
      "lodash-es@>=4.0.0 <=4.17.22": "4.17.23",
      "next@>=16.0.0-beta.0 <16.1.7": "16.1.7",
      "next@>=16.0.1 <16.1.7": "16.1.7",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "yaml@>=2.0.0 <2.8.3": "2.8.3",
      "@xmldom/xmldom@>=0.9.0 <0.9.9": "0.9.9",
      "lodash-es@>=4.0.0 <=4.17.23": "4.18.0",
      "lodash-es@<=4.17.23": "4.18.0",
      "vite@>=7.0.0 <=7.3.1": "7.3.2",
      "vite@>=7.1.0 <=7.3.1": "7.3.2"
    }
  }
}
