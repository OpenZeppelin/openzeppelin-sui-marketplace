{
  "name": "dapp",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Oracle Market",
  "scripts": {
    "ui": "pnpm --filter ui",
    "script": "pnpm --filter dapp",
    "dapp": "pnpm --filter dapp",
    "learn": "pnpm --filter learn",
    "tooling": "pnpm --filter tooling",
    "typecheck": "tsc -b",
    "lint": "eslint \"packages/**/*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}\"",
    "lint:fix": "eslint --fix \"packages/**/*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.19.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  },
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "packages/*/*"
  ],
  "pnpm": {
    "overrides": {
      "axios": ">=1.13.5",
      "@isaacs/brace-expansion": ">=5.0.1",
      "minimatch": "10.2.4",
      "rollup": "4.59.0",
      "lodash-es@>=4.0.0 <=4.17.22": "4.17.23",
      "diff@>=4.0.0 <4.0.4": "4.0.4",
      "ajv@<6.14.0": "6.14.0",
      "dompurify@>=3.1.3 <=3.3.1": "3.3.2",
      "flatted@<3.4.0": "3.4.0",
      "next@>=16.0.0-beta.0 <16.1.7": "16.1.7",
      "flatted@<=3.4.1": "3.4.2",
      "next@>=16.0.1 <16.1.7": "16.1.7"
    }
  }
}
