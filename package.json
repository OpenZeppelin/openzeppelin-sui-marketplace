{
  "name": "dapp",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Oracle Market",
  "scripts": {
    "ui": "pnpm --filter ui",
    "script": "pnpm --filter dapp",
    "dapp": "pnpm --filter dapp",
    "learn": "pnpm --filter learn",
    "tooling": "pnpm --filter tooling",
    "typecheck": "tsc -b",
    "lint": "eslint \"packages/**/*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}\"",
    "lint:fix": "eslint --fix \"packages/**/*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.15",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "packages/*/*"
  ],
  "pnpm": {
    "overrides": {
      "axios": ">=1.13.5",
      "@isaacs/brace-expansion": ">=5.0.1",
      "minimatch": "10.2.4"
    }
  }
}
