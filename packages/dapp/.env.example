# Network: localnet | testnet | mainnet
SUI_NETWORK=localnet

# ── Owner account ─────────────────────────────────────────────────────────────
# Signs all owner scripts: move:publish, mock:setup, owner:shop:seed,
# owner:item-listing:*, owner:discount:*, owner:currency:*
SUI_ACCOUNT_ADDRESS=
SUI_ACCOUNT_PRIVATE_KEY=
# SUI_ACCOUNT_MNEMONIC=    # alternative to PRIVATE_KEY

# ── Buyer account (localnet only) ─────────────────────────────────────────────
# Signs buyer CLI scripts automatically: buyer:buy
# On testnet the buyer interacts via browser wallet (Slush) — leave these empty
# Also used as the funding target for mock:setup (replaces --buyer-address flag)
SUI_BUYER_ACCOUNT_ADDRESS=
SUI_BUYER_ACCOUNT_PRIVATE_KEY=
# SUI_BUYER_ACCOUNT_MNEMONIC=    # alternative to PRIVATE_KEY